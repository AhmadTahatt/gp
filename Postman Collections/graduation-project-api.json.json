				{
					"name": "2.1 Get All Courses",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
									"pm.test('Returns array of courses', () => {",
									"  const courses = pm.response.json();",
									"  pm.expect(Array.isArray(courses)).to.be.true;",
									"  pm.expect(courses.length).to.be.above(0);",
									"  pm.collectionVariables.set('course_id', courses[0].id);",
									"  console.log('Saved course_id:', courses[0].id);",
									"});",
									"pm.test('Courses have required fields', () => {",
									"  const c = pm.response.json()[0];",
									"  pm.expect(c).to.have.property('id');",
									"  pm.expect(c).to.have.property('course_code');",
									"  pm.expect(c).to.have.property('title');",
									"  pm.expect(c).to.have.property('credits');",
									"});"
