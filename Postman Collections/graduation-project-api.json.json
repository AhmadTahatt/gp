			"name": "1. Authentication",
			"item": [
				{
					"name": "1.1 Login - Student",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
									"pm.test('Has access_token', () => {",
									"  const j = pm.response.json();",
									"  pm.expect(j).to.have.property('access_token');",
									"  pm.collectionVariables.set('student_token', j.access_token);",
									"  console.log('Student token saved');",
									"});"
								],
								"type": "text/javascript",
